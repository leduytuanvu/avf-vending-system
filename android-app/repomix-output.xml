                key = { it.slotId },
                contentType = { "product" },
            ) { productSlot ->
                ProductCard(
                    name = productSlot.name,
                    price = productSlot.price,
                    slotAddress = productSlot.slotAddress,
                    stock = productSlot.stock,
                    onClick = { onProductSelected(productSlot) },
                )
            }
        }
    }
}
