@Composable
fun ProductGrid(
    items: List<StorefrontItemUiModel>,
    isLoading: Boolean,
    onProductSelected: (StorefrontItemUiModel) -> Unit,
    modifier: Modifier = Modifier,
) {
    LazyVerticalGrid(
        columns = GridCells.Adaptive(minSize = 180.dp),
